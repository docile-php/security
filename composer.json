{
    "name": "docile/security",
    "description": "Authentication, authorization, CSRF, rate limiting and signed URLs for Docile",
    "type": "library",
    "license": "MIT",
    "authors": [{"name": "Ali Naqi Al-Musawi", "email": "alinaqi2000@gmail.com"}],
    "require": {
        "php": "^8.3",
        "ext-sodium": "*",
        "psr/clock": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0",
        "psr/simple-cache": "^3.0",
        "docile/foundation": "*",
        "docile/support": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {"psr-4": {"Docile\\Security\\": "src/"}},
    "autoload-dev": {"psr-4": {"Docile\\Security\\Tests\\": "tests/"}}
}
